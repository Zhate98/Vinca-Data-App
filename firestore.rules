rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Perfil personal y todas sus subcolecciones ─────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Espacios compartidos ───────────────────────────────────────────────
    match /shared_spaces/{spaceId} {

      // Cualquier usuario autenticado puede leer el documento del espacio
      // (necesario para buscar por código al unirse)
      allow read: if isLoggedIn();

      // Crear: el uid debe estar en members y ser el creador
      allow create: if isLoggedIn()
                    && request.auth.uid in request.resource.data.members
                    && request.resource.data.createdBy == request.auth.uid;

      // Actualizar: miembros actuales O usuario que se une (solo añade su propio uid)
      allow update: if isLoggedIn() && (
        isMember(resource.data.members) ||
        (
          request.resource.data.members.hasAll(resource.data.members) &&
          request.resource.data.members.size() == resource.data.members.size() + 1 &&
          request.auth.uid in request.resource.data.members
        )
      );

      // Eliminar: solo el creador
      allow delete: if isLoggedIn()
                    && resource.data.createdBy == request.auth.uid;

      // Subcolecciones: solo miembros
      match /{subcollection}/{document} {
        allow read, write: if isLoggedIn() && isMember(
          get(/databases/$(database)/documents/shared_spaces/$(spaceId)).data.members
        );
      }
    }

    // ── Bloqueo por defecto ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isMember(members) {
      return request.auth.uid in members;
    }
  }
}
